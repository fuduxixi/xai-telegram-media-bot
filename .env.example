# =============================
# xAI Telegram Media Bot 配置示例
# Author: by fuduxixi
# =============================
# 说明：
# 1. 复制为 .env 后再填写真实值
# 2. Telegram Bot Token 必填
# 3. XAI_API_KEY 或 XAI_API_KEYS 至少填一个
# 4. Docker Web 端口映射默认用 docker-compose.yml 里的 WEB_PORT（默认 5112）
# 5. 下面大部分变量都有默认值，不填则使用代码内默认配置

# -------------------------------------------------
# Telegram 基础配置
# -------------------------------------------------

# Telegram 机器人 token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=1234567890:replace_me

# 允许使用机器人的 Telegram 用户 ID
# 多个用英文逗号分隔；留空表示所有人可用
TG_ALLOWED_USER_IDS=123456789

# -------------------------------------------------
# xAI API 配置
# -------------------------------------------------

# 单个 xAI API Key（推荐先填这个）
XAI_API_KEY=xai-replace_me

# 多个 xAI API Key（多个用英文逗号分隔）
# 如果填写了这个，脚本会优先使用它，而不是 XAI_API_KEY
XAI_API_KEYS=xai-key-1,xai-key-2,xai-key-3

# -------------------------------------------------
# 图片生成默认配置
# -------------------------------------------------

# 默认图片模型：
# 可选：grok-imagine-image / grok-imagine-image-pro
XAI_IMAGE_MODEL=grok-imagine-image

# 默认图片比例
# 常见值：1:1 / 4:5 / 16:9 / 9:16 / auto
XAI_IMAGE_DEFAULT_RATIO=1:1

# 默认图片生成数量
# 当前建议 1，最大支持 4
XAI_IMAGE_DEFAULT_N=1

# 允许的最大图片生成数量
# 脚本内部会限制到 1~4 之间
XAI_IMAGE_MAX_N=4

# -------------------------------------------------
# 视频 / 图生视频配置
# -------------------------------------------------

# 当视频或图生视频因为内容审核被拒绝时：
# 兼容旧开关：0 = 关闭，1 = 开启（等价于 mild）
VIDEO_AUTO_REWRITE_ON_MODERATION=1

# 新版两档改写模式：off / mild / strong
# off    = 关闭自动改写
# mild   = 轻度改写，尽量保留原始镜头与动作
# strong = 强力改写，更保守，更容易过审
VIDEO_REWRITE_MODE=mild

# -------------------------------------------------
# 日志与运行配置
# -------------------------------------------------

# 机器人日志级别
# 可选：DEBUG / INFO / WARNING / ERROR
BOT_LOG_LEVEL=INFO

# Bot 日志文件路径（主要给 Docker + Web 后台查看日志用）
BOT_LOG_FILE=/app/logs/bot.log

# Bot 状态文件路径（主要给 Web 后台显示在线状态用）
BOT_STATUS_FILE=/app/data/bot-status.json

# Bot 热重载信号文件路径（Web 保存配置后会写这个文件）
BOT_RELOAD_SIGNAL_FILE=/app/data/reload-bot.signal

# -------------------------------------------------
# Web 配置界面配置
# -------------------------------------------------

# Web 配置界面登录用户名
ADMIN_USER=admin

# Web 配置界面登录密码
# 强烈建议修改默认值
ADMIN_PASSWORD=admin123

# Flask Session 密钥（必填）
# 请使用高强度随机字符串，例如：openssl rand -hex 32
WEB_SECRET_KEY=replace_with_a_long_random_secret

# Web 配置界面容器内部监听端口
# 一般保持 5000 即可，外网访问端口由 docker-compose 的 WEB_PORT 控制
WEB_CONFIG_PORT=5000

# -------------------------------------------------
# Docker / Compose 使用说明（不是程序读取的变量）
# -------------------------------------------------

# docker-compose.yml 默认端口映射写的是：
#   ${WEB_PORT:-5112}:5000
# 所以你启动时可以这样指定外网访问端口：
#   WEB_PORT=5112 docker compose up -d --build
# 或者改成：
#   WEB_PORT=8080 docker compose up -d --build
